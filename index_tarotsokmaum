<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>🦄 유니콘타로 · 그 사람의 속마음</title>
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
/* ── 글로벌 & 리셋 ── */
*,*::before,*::after {box-sizing:border-box;margin:0;padding:0;}
:root {
    --bg-deep: #0F0A1E;
    --bg-navy: #1A1230;
    --bg-card: rgba(30, 20, 50, 0.85);
    
    --unicorn-light: #FBCFE8; /* 핑크 */
    --unicorn-main: #D8B4FE;  /* 보라 */
    --unicorn-cyan: #A5F3FC;  /* 시안 */
    
    --unicorn-grad: linear-gradient(135deg, #F472B6 0%, #A855F7 50%, #60A5FA 100%);
    --text-grad: linear-gradient(to bottom, #FFFFFF 0%, #FBCFE8 50%, #D8B4FE 100%);
    
    --pink-btn: linear-gradient(180deg, #F472B6 0%, #DB2777 40%, #9D174D 100%);
    --purple-btn: linear-gradient(180deg, #A855F7 0%, #7E22CE 40%, #4C1D95 100%);

    --text-main: #F8FAFC;
    --text-sub: #CBD5E1;
    --text-mut: #64748B;

    --font-body: 'Noto Sans KR', sans-serif;
    --font-serif: 'Black Han Sans', sans-serif;
}

html, body {
    background-color: var(--bg-deep);
    font-family: var(--font-body);
    color: var(--text-main);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}

#app {
    max-width: 430px;
    margin: 0 auto;
    min-height: 100vh;
    background: linear-gradient(175deg, #0F0A1E 0%, #1A1230 20%, #2D1B4D 40%, #1A1230 60%, #3B1B5B 80%, #0F0A1E 100%);
    position: relative;
    box-shadow: 0 0 50px rgba(0,0,0,1);
    overflow: hidden;
}

/* ── 타이포그래피 ── */
.title-black { font-family: var(--font-serif); font-weight: 400; letter-spacing: -0.5px; line-height: 1.3; }
.text-unicorn-3d {
    background: var(--text-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
}
.text-super-neon {
    background: linear-gradient(to bottom, #FFFFFF 0%, #FBCFE8 30%, #D8B4FE 70%, #A855F7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(216, 180, 254, 0.8));
    animation: neonPulse 2s infinite alternate ease-in-out;
}
@keyframes neonPulse {
    0% { filter: drop-shadow(0 0 5px rgba(216, 180, 254, 0.5)); }
    100% { filter: drop-shadow(0 0 15px rgba(244, 114, 182, 0.8)); transform: scale(1.01); }
}

/* ── 입체 버튼 ── */
.btn-3d-unicorn {
    width: 100%; padding: 18px; border-radius: 50px;
    border: 1px solid #FBCFE8; background: var(--unicorn-grad);
    color: #fff; font-size: 18px; font-weight: 700;
    cursor: pointer; position: relative; overflow: hidden;
    box-shadow: 0 6px 0 #7E22CE, 0 15px 20px rgba(168,85,247,0.4);
    transition: all 0.1s;
}
.btn-3d-unicorn:active { 
    transform: translateY(6px); 
    box-shadow: 0 0 0 #7E22CE, 0 5px 10px rgba(168,85,247,0.4);
}

/* ── 폼 스타일 ── */
.form-card {
    background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px; padding: 28px 24px; margin: 0 20px;
}
.inp {
    width: 100%; padding: 16px; border-radius: 14px; background: #0F0A1E;
    border: 1px solid rgba(255, 255, 255, 0.1); color: #fff; font-size: 16px;
    outline: none; transition: all 0.2s;
}
.inp:focus { border-color: var(--unicorn-light); box-shadow: 0 0 15px rgba(244, 114, 182, 0.3); }
.lbl { font-size: 14px; color: var(--unicorn-light); margin-bottom: 8px; display: block; font-weight: 700; }
.radio-row { display: flex; gap: 10px; }
.rb {
    flex: 1; padding: 14px; border-radius: 14px; text-align: center; background: #0F0A1E;
    border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer; color: var(--text-mut); font-weight: 700;
}
.rb.on {
    background: var(--unicorn-grad); color: #fff; border-color: transparent;
}

/* ── 진행바 ── */
.step-progress-bar {
    position: sticky; top: 0; z-index: 50; background: rgba(15, 10, 30, 0.9); backdrop-filter: blur(10px); padding: 15px 20px;
}
.step-bar-track { width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
.step-bar-fill { height: 100%; background: var(--unicorn-grad); transition: width 0.3s; }

/* ── 유니콘 수정구슬 애니메이션 ── */
.orb-wrapper {
    position: relative; width: 280px; height: 280px; margin: 0 auto; display: flex; align-items: center; justify-content: center;
}
.orb-main {
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #fff, #FBCFE8 20%, #A855F7 60%, #60A5FA 100%);
    box-shadow: 0 0 50px rgba(168, 85, 247, 0.6), inset -10px -10px 50px rgba(0,0,0,0.5);
    animation: orbFloat 4s infinite ease-in-out;
}
@keyframes orbFloat { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-20px) scale(1.05); } }

/* ── 섹션 공통 ── */
.page { display: none; flex-direction: column; min-height: 100vh; }
.page.active { display: flex; animation: fadeIn 0.4s ease-out; }
@keyframes fadeIn { from{opacity:0; transform:translateY(10px)} to{opacity:1; transform:translateY(0)} }
.section-padding { padding: 40px 20px; }

/* 토스트 */
#live-toast {
    position:fixed; bottom: 120px; left:50%; transform:translateX(-50%); background:rgba(255,255,255,0.9); color:#4C1D95; padding:10px 20px; border-radius:30px; font-size:13px; font-weight:700; opacity:0; transition:0.5s; z-index:1000;
}
#live-toast.show { opacity: 1; }

/* 타로 카드 리스트 */
.tarot-pick-container { display: flex; justify-content: center; gap: 8px; margin: 30px 0; perspective: 1000px; }
.tarot-pick-card {
    width: 65px; height: 110px; background: #2D1B4D; border: 2px solid var(--unicorn-main); border-radius: 8px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; font-size: 24px; transition: 0.3s;
}
.tarot-pick-card:hover { transform: translateY(-10px); border-color: var(--unicorn-light); }

/* 리뷰 카드 */
.review-card {
    background: rgba(255, 255, 255, 0.05); border-radius: 20px; padding: 20px; margin-bottom: 12px; border: 1px solid rgba(255,255,255,0.1);
}
</style>
</head>
<body>
<div id="app">

<div id="live-toast">방금 '서**'님이 속마음을 확인하셨어요! 🦄</div>

<div id="p0" class="page active">
    <div style="text-align:center; padding-top:40px;">
        <div style="font-size:14px; color:var(--unicorn-light); font-weight:700; letter-spacing:2px; margin-bottom:10px;">MYSTIC UNICORN TAROT</div>
        <h1 class="title-black text-super-neon" style="font-size:38px; line-height:1.2;">
            그 사람이 숨긴<br>진짜 속마음은?
        </h1>
    </div>

    <div class="orb-wrapper">
        <div class="orb-main"></div>
        <div style="position:absolute; font-size:100px; filter:grayscale(0.5) opacity(0.3);">🦄</div>
    </div>

    <div style="text-align:center; padding:0 20px; margin-top:-20px;">
        <div class="title-black text-unicorn-3d" style="font-size:22px; margin-bottom:15px;">
            "나를 어떻게 생각할까?"<br>혼자 앓던 고민, 이제 끝내세요.
        </div>
        <p style="font-size:15px; color:var(--text-sub); line-height:1.6;">
            사주로 보는 성향 분석과<br>타로가 읽어내는 무의식의 결합.<br>국내 유일 99% 적중률의 속마음 리포트.
        </p>
    </div>

    <div class="section-padding">
        <div class="title-black" style="font-size:24px; text-align:center; margin-bottom:25px;">상담 만족도 후기 💖</div>
        <div class="review-card">
            <div style="color:var(--unicorn-light); margin-bottom:8px;">★★★★★</div>
            <div style="font-size:14px; color:var(--text-sub); line-height:1.5;">
                "짝사랑 상대가 절 친구로만 생각하는 줄 알았는데, 분석 결과 보고 용기내서 연락했다가 사귀게 됐어요! 진짜 소름 돋아요."
            </div>
            <div style="font-size:12px; color:var(--text-mut); margin-top:10px;">dan***님 · 타로 6번 카드</div>
        </div>
        <div class="review-card">
            <div style="color:var(--unicorn-light); margin-bottom:8px;">★★★★★</div>
            <div style="font-size:14px; color:var(--text-sub); line-height:1.5;">
                "헤어진 남자친구 속마음이 궁금해서 봤는데, 나중에 연락와서 하는 말이 리포트 내용이랑 토씨 하나 안 틀리고 똑같아서 무서웠어요."
            </div>
            <div style="font-size:12px; color:var(--text-mut); margin-top:10px;">lee***님 · 타로 2번 카드</div>
        </div>
    </div>

    <div style="height:120px;"></div>

    <div style="position:fixed; bottom:0; left:0; right:0; max-width:430px; margin:0 auto; padding:20px; background:linear-gradient(to top, var(--bg-deep) 80%, transparent); z-index:100;">
        <button class="btn-3d-unicorn" onclick="startStep(1)">🦄 990원에 속마음 엿보기</button>
        <p style="text-align:center; font-size:12px; color:var(--text-mut); margin-top:10px;">이미 12,402명이 확인하셨어요!</p>
    </div>
</div>

<div id="p_input" class="page">
    <div class="step-progress-bar">
        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span id="step-label" style="font-size:12px; color:var(--unicorn-light);">정보 입력</span>
            <span id="step-pct" style="font-size:14px; font-weight:700;">20%</span>
        </div>
        <div class="step-bar-track"><div class="step-bar-fill" id="step-bar-fill" style="width:20%;"></div></div>
    </div>

    <div style="padding:40px 24px;">
        <div class="step-card active" id="step-1">
            <h2 class="title-black" style="font-size:26px; margin-bottom:10px;">당신의 이름은?</h2>
            <p style="color:var(--text-sub); margin-bottom:30px;">더 정확한 운세 공명을 위해 필요해요.</p>
            <label class="lbl">이름 (또는 닉네임)</label>
            <input class="inp" id="i-name" type="text" placeholder="이름을 입력하세요">
        </div>

        <div class="step-card" id="step-2" style="display:none;">
            <h2 class="title-black" style="font-size:26px; margin-bottom:10px;">당신의 생일은?</h2>
            <p style="color:var(--text-sub); margin-bottom:30px;">태어난 시간은 몰라도 괜찮아요!</p>
            <label class="lbl">생년월일 (8자리)</label>
            <input class="inp" id="i-birth" type="tel" placeholder="예: 19950508" maxlength="8">
            <div style="margin-top:20px;">
                <label class="lbl">양력/음력</label>
                <div class="radio-row">
                    <div class="rb on" id="l-y" onclick="pickL('양력')">양력</div>
                    <div class="rb" id="l-n" onclick="pickL('음력')">음력</div>
                </div>
            </div>
        </div>

        <div class="step-card" id="step-3" style="display:none;">
            <h2 class="title-black" style="font-size:26px; margin-bottom:10px;">상대방은 누구인가요?</h2>
            <p style="color:var(--text-sub); margin-bottom:30px;">그 사람을 떠올리며 입력해주세요.</p>
            <div style="margin-bottom:15px;">
                <label class="lbl">상대방 이름(호칭)</label>
                <input class="inp" id="p-name" type="text" placeholder="예: 철수, 그분">
            </div>
            <div style="margin-bottom:15px;">
                <label class="lbl">우리 사이의 관계</label>
                <select class="inp" id="p-rel">
                    <option value="썸">썸타는 중</option>
                    <option value="짝사랑">내가 짝사랑 중</option>
                    <option value="연애">달달하게 연애 중</option>
                    <option value="권태기">아슬아슬한 권태기</option>
                    <option value="이별">헤어진 사이 (재회 희망)</option>
                    <option value="친구">그냥 친구 사이</option>
                </select>
            </div>
        </div>

        <div class="step-card" id="step-4" style="display:none;">
            <h2 class="title-black" style="font-size:26px; margin-bottom:10px;">상대방의 생일은?</h2>
            <p style="color:var(--text-sub); margin-bottom:30px;">모르신다면 대략적인 연도라도 좋아요.</p>
            <label class="lbl">생년월일 (8자리)</label>
            <input class="inp" id="p-birth" type="tel" placeholder="예: 19941225" maxlength="8">
            <div style="margin-top:20px;">
                <label class="lbl">양력/음력</label>
                <div class="radio-row">
                    <div class="rb on" id="pl-y" onclick="pickPL('양력')">양력</div>
                    <div class="rb" id="pl-n" onclick="pickPL('음력')">음력</div>
                </div>
            </div>
        </div>

        <div class="step-card" id="step-5" style="display:none;">
            <h2 class="title-black" style="font-size:26px; margin-bottom:10px;">결과를 어디로 보낼까요?</h2>
            <p style="color:var(--text-sub); margin-bottom:30px;">분석된 비밀 리포트가 전송됩니다.</p>
            <label class="lbl">이메일 주소</label>
            <input class="inp" id="i-email" type="email" placeholder="example@email.com">
        </div>
    </div>

    <div style="position:fixed; bottom:0; left:0; right:0; max-width:430px; margin:0 auto; padding:20px; display:flex; gap:10px;">
        <button id="btn-prev" onclick="prevStep()" style="display:none; width:60px; height:60px; border-radius:50%; background:#1A1230; border:1px solid var(--unicorn-main); color:#fff;">←</button>
        <button class="btn-3d-unicorn" id="btn-next" onclick="nextStep()" style="flex:1;">다음으로 →</button>
    </div>
</div>

<div id="p_tarot" class="page" style="align-items:center; justify-content:center; text-align:center;">
    <h2 class="title-black text-unicorn-3d" style="font-size:28px; margin-bottom:15px;">그 사람을 깊게 생각하며<br>카드 1장을 선택하세요</h2>
    <p style="color:var(--text-sub); font-size:14px; margin-bottom:30px;">당신의 직관이 그 사람의 무의식과 연결됩니다.</p>
    
    <div class="tarot-pick-container">
        <div class="tarot-pick-card" onclick="selectTarot()">🦄</div>
        <div class="tarot-pick-card" onclick="selectTarot()">🦄</div>
        <div class="tarot-pick-card" onclick="selectTarot()">🦄</div>
        <div class="tarot-pick-card" onclick="selectTarot()">🦄</div>
        <div class="tarot-pick-card" onclick="selectTarot()">🦄</div>
    </div>
    <p style="font-size:12px; color:var(--text-mut); animation:fade 1.5s infinite;">카드를 탭하면 분석이 시작됩니다</p>
</div>

</div><script src="https://js.tosspayments.com/v2/standard"></script>
<script>
// ⚙️ 설정
var CONFIG = {
    PRODUCT_NAME: '유니콘타로 상대방 속마음 정밀 분석',
    PRICE: 990, // 가격 990원
    SUCCESS_URL: window.location.href,
    FAIL_URL: window.location.href
};

var S = { name:'', birth:'', lunar:'양력', pName:'', pRel:'썸', pBirth:'', pLunar:'양력', email:'', step:1 };

function startStep(n) {
    showP('p_input');
    updateStepUI();
}

function updateStepUI() {
    document.querySelectorAll('.step-card').forEach(c => c.style.display = 'none');
    document.getElementById('step-' + S.step).style.display = 'block';
    
    var pct = (S.step / 5) * 100;
    document.getElementById('step-bar-fill').style.width = pct + '%';
    document.getElementById('step-pct').textContent = pct + '%';
    document.getElementById('btn-prev').style.display = S.step > 1 ? 'block' : 'none';
    document.getElementById('btn-next').textContent = S.step === 5 ? '속마음 분석 시작하기 🔮' : '다음으로 →';
}

function nextStep() {
    if (S.step === 1 && !document.getElementById('i-name').value) return alert('이름을 입력해주세요.');
    if (S.step === 2 && document.getElementById('i-birth').value.length < 8) return alert('생년월일 8자리를 입력해주세요.');
    if (S.step === 5 && !document.getElementById('i-email').value) return alert('이메일을 입력해주세요.');
    
    if (S.step < 5) {
        S.step++;
        updateStepUI();
    } else {
        showP('p_tarot');
    }
}

function prevStep() {
    if (S.step > 1) {
        S.step--;
        updateStepUI();
    }
}

function pickL(l) { S.lunar = l; document.getElementById('l-y').className = 'rb'+(l==='양력'?' on':''); document.getElementById('l-n').className = 'rb'+(l==='음력'?' on':''); }
function pickPL(l) { S.pLunar = l; document.getElementById('pl-y').className = 'rb'+(l==='양력'?' on':''); document.getElementById('pl-n').className = 'rb'+(l==='음력'?' on':''); }

function selectTarot() {
    alert('그 사람의 무의식 에너지를 스캔했습니다! 결제 페이지로 이동합니다.');
    goPay();
}

function goPay() {
    alert('990원 결제창으로 연결됩니다. (테스트 환경)');
    // 실제 Toss Payments 연동 로직은 여기에 위치
}

function showP(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0,0);
}

// 토스트 애니메이션
setInterval(() => {
    var toast = document.getElementById('live-toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
}, 8000);

</script>
</body>
</html>
